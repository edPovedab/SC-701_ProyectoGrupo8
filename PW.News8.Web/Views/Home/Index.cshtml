@{
    ViewData["Title"] = "Inicio";
}

<section class="hero rounded-4 p-5 mb-5 text-white">
    <div class="row align-items-center">
        <div class="col-lg-8">
            <h1 class="display-5 fw-bold mb-3">Agrega, lee y guarda noticias de múltiples fuentes</h1>
            <p class="lead mb-4">
                News8 centraliza fuentes y permite leerlas en vivo,
                guardar los ítems que interesan y exportarlos e importarlos en archivos  tipo JSON.
            </p>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Sources" asp-action="Index" class="btn btn-light btn-lg">Ver fuentes</a>
                <a asp-controller="Sources" asp-action="Upload" class="btn btn-outline-light btn-lg">Subir JSON</a>
            </div>
        </div>
    </div>
</section>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100 feature-card">
            <div class="card-body">
                <div class="feature-icon mb-3">&#128225;</div>
                <h3 class="h5">Múltiples formatos</h3>
                <p class="text-muted mb-0">
                 La API la interpreta
                 con el lector correspondiente.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 feature-card">
            <div class="card-body">
                <div class="feature-icon mb-3">&#9889;</div>
                <h3 class="h5">Lectura en vivo</h3>
                <p class="text-muted mb-0">
                    Consulta una fuente en tiempo real antes de decidir qué ítems
                    guardar en la base de datos.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 feature-card">
            <div class="card-body">
                <div class="feature-icon mb-3">&#128190;</div>
                <h3 class="h5">Exportar / Importar</h3>
                <p class="text-muted mb-0">
                    Descarga una fuente y sus ítems como JSON.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="card bg-light border-0">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="h5 mb-1">Arquitectura del proyecto</h2>
            <p class="text-muted mb-0"></p>
        </div>
        <a asp-controller="Sources" asp-action="Index" class="btn btn-primary">Empezar &rarr;</a>
    </div>
</div>