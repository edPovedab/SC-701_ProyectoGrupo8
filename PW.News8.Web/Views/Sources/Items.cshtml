@model PW.News8.Shared.DTOs.SourceDto

@{
    ViewData["Title"] = $"Ítems · {Model.Name}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Sources" asp-action="Index">Fuentes</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-1">@Model.Name</h1>
        <p class="text-muted mb-0">@Model.Url</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" id="btn-fetch-live" class="btn btn-outline-primary">
            Leer en vivo
        </button>
        <a id="btn-download" asp-controller="Sources" asp-action="Download" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            Descargar JSON
        </a>
    </div>
</div>

<div id="live-fetch-panel" class="card mb-4 d-none">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Lectura en vivo</span>
        <button type="button" class="btn-close" id="btn-close-live-panel" aria-label="Cerrar"></button>
    </div>
    <div class="card-body" id="live-fetch-body">
      
    </div>
</div>

<h2 class="h5 mb-3">Ítems guardados</h2>
<div id="items-container">
    <div class="text-center text-muted py-5" id="items-loading">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
        Cargando ítems…
    </div>
</div>


<div class="modal fade" id="jsonModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalle del ítem</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <pre id="jsonModalBody" class="json-preview"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sources.js" asp-append-version="true"></script>
    <script>
        $(function () {
        const sourceId = @Model.Id;loadItemsList(sourceId);

        $('#btn-fetch-live').on('click', function () {
        fetchLive(sourceId);
        });

        $('#btn-close-live-panel').on('click', function () {
        $('#live-fetch-panel').addClass('d-none');
        });
        });
    </script>
}