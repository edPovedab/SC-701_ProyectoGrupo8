@model PW.News8.Shared.DTOs.SourceDto

@{
    var badgeClass = Model.ComponentType?.ToLowerInvariant() switch
    {
        "json" => "badge-type-json",
        "xml" => "badge-type-xml",
        "html" => "badge-type-html",
        _ => "badge-type-default"
    };
}

<div class="col-md-6 col-lg-4 source-card-col">
    <div class="card source-card h-100">
        <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title mb-0">@Model.Name</h5>
                <span class="badge type-badge @badgeClass">@Model.ComponentType</span>
            </div>
            <p class="card-text text-muted small text-truncate mb-2" title="@Model.Url">@Model.Url</p>
            <p class="card-text flex-grow-1">@(string.IsNullOrWhiteSpace(Model.Description) ? "Sin descripción." : Model.Description)</p>

            @if (Model.RequiresSecret)
            {
                <span class="badge secret-badge align-self-start mb-2">Requiere Secret</span>
            }

            <a asp-controller="Sources" asp-action="Items" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm mt-auto">
                Ver ítems
            </a>
        </div>
    </div>
</div>