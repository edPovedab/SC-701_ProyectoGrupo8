@model PW.News8.Shared.DTOs.NewsResultDto

@if (!Model.Success)
{
    <div class="alert alert-warning mb-0">@(Model.ErrorMessage ?? "No se pudieron obtener noticias en este momento.")</div>
}
else if (Model.Items.Count == 0)
{
    <partial name="_EmptyState" model='"No se encontraron noticias con estos filtros."' />
}
else
{
    <div class="row g-4">
        @foreach (var item in Model.Items)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card news-card h-100">
                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="card-img-top news-card-img" alt="" onerror="this.style.display='none'" />
                    }
                    <div class="card-body d-flex flex-column">
                        <span class="badge news-source-badge align-self-start mb-2">@item.SourceName</span>
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-text text-muted small flex-grow-1">
                            @(string.IsNullOrWhiteSpace(item.Description) ? "" : item.Description)
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-auto pt-2">
                            <small class="text-muted">@(item.PublishedAt?.ToLocalTime().ToString("dd MMM, HH:mm") ?? "")</small>
                            <a href="@item.Url" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">Leer más</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
